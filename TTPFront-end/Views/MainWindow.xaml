<Window x:Class="TTPFrontEnd.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:TTPFrontEnd.ViewModels"
        mc:Ignorable="d"
        Title="铁路票务系统"
        Width="1060" Height="700"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 顶部导航 -->
            <RowDefinition Height="*"/>      <!-- 内容区 -->
        </Grid.RowDefinitions>

        <!-- ==================== 顶部导航栏 ==================== -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="0">
            <Grid Height="56">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + 标题 -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="20,0,0,0">
                    <TextBlock Text="🚄" FontSize="22" VerticalAlignment="Center"/>
                    <TextBlock Text="铁路票务系统"
                               FontSize="17"
                               FontWeight="Bold"
                               Foreground="#333"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"/>
                </StackPanel>

                <!-- 导航按钮 -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button Content="车次查询"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="车次查询"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#555"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Padding" Value="16,0"/>
                                <Setter Property="Height" Value="56"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0F4FF"/>
                                        <Setter Property="Foreground" Value="#4A90D9"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="车次查询">
                                        <Setter Property="Foreground" Value="#4A90D9"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="我的订单"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="我的订单"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#555"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Padding" Value="16,0"/>
                                <Setter Property="Height" Value="56"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0F4FF"/>
                                        <Setter Property="Foreground" Value="#4A90D9"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="我的订单">
                                        <Setter Property="Foreground" Value="#4A90D9"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- 管理员可见：后台管理 -->
                    <Button Content="后台管理"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="后台管理"
                            Cursor="Hand"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#555"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Padding" Value="16,0"/>
                                <Setter Property="Height" Value="56"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFF8ED"/>
                                        <Setter Property="Foreground" Value="#E67E22"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="后台管理">
                                        <Setter Property="Foreground" Value="#E67E22"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="个人中心"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="个人中心"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#555"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Padding" Value="16,0"/>
                                <Setter Property="Height" Value="56"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0F4FF"/>
                                        <Setter Property="Foreground" Value="#4A90D9"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="个人中心">
                                        <Setter Property="Foreground" Value="#4A90D9"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- 用户信息 -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0">
                    <TextBlock Text="{Binding WelcomeText}"
                               FontSize="13"
                               Foreground="#888"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== 内容区 ==================== -->

        <!-- 车次查询页面 -->
        <Grid Grid.Row="1"
              Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=车次查询}"
              Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 搜索栏 -->
            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,12"
                    BorderBrush="#E8E8E8"
                    BorderThickness="1">
                <StackPanel>
                    <!-- 第一行：出发站 / 交换按钮 / 到达站 / 日期 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 出发站 -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="出发站" FontSize="12" Foreground="#888" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding TrainQuery.Stations}"
                                      SelectedItem="{Binding TrainQuery.SelectedFromStation}"
                                      DisplayMemberPath="Name"
                                      Height="38"
                                      FontSize="14"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      TextSearch.TextPath="Name"
                                      Padding="8,0"/>
                        </StackPanel>

                        <!-- 交换按钮 -->
                        <Button Grid.Column="1"
                                Command="{Binding TrainQuery.SwapStationsCommand}"
                                Width="36" Height="36"
                                Margin="12,18,12,0"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="交换出发/到达站">
                            <TextBlock Text="⇄" FontSize="20" Foreground="#4A90D9"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <!-- 到达站 -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="到达站" FontSize="12" Foreground="#888" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding TrainQuery.Stations}"
                                      SelectedItem="{Binding TrainQuery.SelectedToStation}"
                                      DisplayMemberPath="Name"
                                      Height="38"
                                      FontSize="14"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      TextSearch.TextPath="Name"
                                      Padding="8,0"/>
                        </StackPanel>

                        <!-- 日期 -->
                        <StackPanel Grid.Column="4" Margin="24,0,0,0">
                            <TextBlock Text="出发日期" FontSize="12" Foreground="#888" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding TrainQuery.SearchDate}"
                                        Height="38"
                                        FontSize="14"/>
                        </StackPanel>

                        <!-- 查询按钮 -->
                        <Button Grid.Column="5"
                                Content="查  询"
                                Command="{Binding TrainQuery.SearchCommand}"
                                Width="90" Height="38"
                                Margin="16,18,0,0"
                                VerticalAlignment="Center"
                                FontSize="14"
                                FontWeight="Bold"
                                Foreground="White"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#4A90D9"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        BorderThickness="0">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3A7BC8"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#B0C4DE"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <!-- 排序栏 -->
                    <Border Margin="0,12,0,0"
                            Padding="10,8"
                            Background="#F8F9FB"
                            CornerRadius="4"
                            Visibility="{Binding TrainQuery.HasResults, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding TrainQuery.InfoMessage}"
                                       FontSize="12"
                                       Foreground="#666"
                                       VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="排序：" FontSize="12" Foreground="#888"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Button Content="按时间"
                                        Command="{Binding TrainQuery.SortByTimeCommand}"
                                        Width="70" Height="28" FontSize="12"
                                        Foreground="White" BorderThickness="0"
                                        Cursor="Hand" Margin="0,0,4,0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#888"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="3" BorderThickness="0">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TrainQuery.SortByPrice}" Value="False">
                                                    <Setter Property="Background" Value="#4A90D9"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3A7BC8"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="按价格"
                                        Command="{Binding TrainQuery.SortByPriceAscCommand}"
                                        Width="70" Height="28" FontSize="12"
                                        Foreground="White" BorderThickness="0"
                                        Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#888"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="3" BorderThickness="0">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TrainQuery.SortByPrice}" Value="True">
                                                    <Setter Property="Background" Value="#E67E22"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#D35400"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 结果表格 + 错误提示 -->
            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#E8E8E8"
                    BorderThickness="1">

                <Grid>
                    <!-- 错误 -->
                <Border Padding="14,12"
                        CornerRadius="6"
                        Background="#FFF3F3"
                        BorderBrush="#FFD4D4"
                        BorderThickness="1"
                        Margin="16"
                        Visibility="{Binding TrainQuery.ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding TrainQuery.ErrorMessage}"
                               FontSize="13"
                               Foreground="#D93025"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- 空状态 -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TrainQuery.HasResults}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding TrainQuery.IsLoading}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="🔍"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               Opacity="0.3"/>
                    <TextBlock Text="选择出发站和/或到达站，点击查询"
                               FontSize="15"
                               Foreground="#BBB"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"/>
                </StackPanel>

                <!-- 统一结果列表 -->
                <ListView ItemsSource="{Binding TrainQuery.AllRoutes}"
                          SelectedItem="{Binding TrainQuery.SelectedRoute}"
                          Margin="8"
                          BorderThickness="0"
                          Visibility="{Binding TrainQuery.HasResults, Converter={StaticResource BoolToVisibilityConverter}}"
                          MouseDoubleClick="TrainList_MouseDoubleClick">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,6" BorderBrush="#F0F0F0"
                                    BorderThickness="0,0,0,1" CornerRadius="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 车次号 + 标签 -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayTrainNo}"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="#4A90D9"/>
                                        <Border CornerRadius="3" Padding="4,1"
                                                HorizontalAlignment="Left" Margin="0,2,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTransfer}" Value="False">
                                                            <Setter Property="Background" Value="#E3F2FD"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsTransfer}" Value="True">
                                                            <Setter Property="Background" Value="#FFF8ED"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Type}" FontSize="10"
                                                       Foreground="#555"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- 行程信息 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                Margin="8,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <TextBlock Text="{Binding DepartureTime}" FontSize="13"
                                                       FontWeight="Bold" Foreground="#333"/>
                                            <TextBlock Text=" → " FontSize="13" Foreground="#999"
                                                       Margin="4,0"/>
                                            <TextBlock Text="{Binding ArrivalTime}" FontSize="13"
                                                       FontWeight="Bold" Foreground="#333"/>
                                            <TextBlock FontSize="12" Foreground="#999"
                                                       Margin="8,0,0,0">
                                                <Run Text="{Binding Duration, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock FontSize="12" Foreground="#555">
                                            <Run Text="{Binding FromStation, Mode=OneWay}"/>
                                            <Run Text=" → "/>
                                            <Run Text="{Binding ToStation, Mode=OneWay}"/>
                                        </TextBlock>
                                        <!-- 中转站标识 -->
                                        <Border Margin="0,2,0,0"
                                                Visibility="{Binding IsTransfer, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock FontSize="11" Foreground="#E67E22">
                                                <Run Text="🔄 经由 "/>
                                                <Run Text="{Binding TransferStation, Mode=OneWay}"/>
                                                <Run Text=" 换乘"/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>

                                    <!-- 价格 -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <TextBlock FontSize="16" FontWeight="Bold"
                                                   Foreground="#E67E22">
                                            <Run Text="¥"/>
                                            <Run Text="{Binding MinPrice, StringFormat={}{0:F0}, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Text="起" FontSize="10" Foreground="#999"
                                                   HorizontalAlignment="Right"/>
                                    </StackPanel>

                                    <!-- 操作按钮 -->
                                    <Grid Grid.Column="3" VerticalAlignment="Center"
                                          Margin="8,0,0,0">

                                        <!-- 直达：详情 + 购票 -->
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding IsTransfer, Converter={StaticResource InvertBoolToVisibilityConverter}}">
                                            <Button Content="详情"
                                                    Command="{Binding DataContext.TrainQuery.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                    CommandParameter="{Binding}"
                                                    FontSize="12" Foreground="#4A90D9"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand" Padding="6,2" Margin="0,0,8,0"/>
                                            <Button Content="购票"
                                                    Command="{Binding DataContext.TrainQuery.BuyTicketCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                    CommandParameter="{Binding}"
                                                    FontSize="12" FontWeight="Bold"
                                                    Foreground="#E67E22"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand" Padding="6,2"/>
                                        </StackPanel>

                                        <!-- 中转：详情 + 购票 -->
                                        <StackPanel Visibility="{Binding IsTransfer, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Orientation="Horizontal">
                                            <Border Background="#FFF8ED" CornerRadius="4"
                                                    Padding="8,4" BorderBrush="#FFE8C0"
                                                    BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock FontSize="11" Foreground="#E67E22"
                                                               FontWeight="Bold" Text="中转详情"/>
                                                    <ItemsControl ItemsSource="{Binding Legs}"
                                                                  Margin="0,3,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock FontSize="10" Foreground="#888"
                                                                           Margin="0,1,0,0">
                                                                    <Run Text="{Binding TrainNo, Mode=OneWay}"/>
                                                                    <Run Text=" "/>
                                                                    <Run Text="{Binding DepartureTime, Mode=OneWay}"/>
                                                                    <Run Text=" → "/>
                                                                    <Run Text="{Binding ArrivalTime, Mode=OneWay}"/>
                                                                    <Run Text=" ¥"/>
                                                                    <Run Text="{Binding Price, StringFormat={}{0:F0}, Mode=OneWay}"/>
                                                                </TextBlock>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                            <Button Content="购票"
                                                    Command="{Binding DataContext.TrainQuery.BuyTicketCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                    CommandParameter="{Binding}"
                                                    FontSize="12" FontWeight="Bold"
                                                    Foreground="White" Background="#E67E22"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Width="50" Height="28" Margin="6,0,0,0"
                                                    VerticalAlignment="Center">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            CornerRadius="4">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                          VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- 加载遮罩 -->
                <Border Background="#80FFFFFF"
                        Visibility="{Binding TrainQuery.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center"/>
                        <TextBlock Text="查询中..." FontSize="14" Foreground="#888"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                </Grid>
            </Border>
        </Grid>

        <!-- ==================== 我的订单页面 ==================== -->
        <Grid Grid.Row="1"
              Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=我的订单}"
              Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 筛选栏 -->
            <Border Grid.Row="0" Background="White" CornerRadius="8"
                    Padding="14,10" Margin="0,0,0,12"
                    BorderBrush="#E8E8E8" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="订单状态：" FontSize="13" Foreground="#555"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding OrderList.StatusOptions}"
                              SelectedItem="{Binding OrderList.FilterStatus}"
                              Width="110" Height="30" FontSize="13"/>
                    <Button Content="🔄" Click="OrderRefresh_Click" ToolTip="刷新"
                            Width="36" Height="30" FontSize="14"
                            Background="Transparent" BorderBrush="#D0D0D0"
                            BorderThickness="1" Cursor="Hand" Margin="16,0,0,0"/>
                    <TextBlock Text="{Binding OrderList.ErrorMessage}"
                               FontSize="12" Foreground="#D93025"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- 订单列表 -->
            <Border Grid.Row="1" Background="White" CornerRadius="8"
                    BorderBrush="#E8E8E8" BorderThickness="1">
                <Grid>
                    <!-- 加载中 -->
                    <Border Background="#80FFFFFF"
                            Visibility="{Binding OrderList.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="加载中..." FontSize="14" Foreground="#888"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 空状态 -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding OrderList.Orders.Count, Converter={StaticResource ZeroToVisibleConverter}}">
                        <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Opacity="0.3"/>
                        <TextBlock Text="暂无订单" FontSize="15" Foreground="#BBB"
                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>

                    <!-- 订单表格 -->
                    <ListView ItemsSource="{Binding OrderList.Orders}"
                              SelectedItem="{Binding OrderList.SelectedOrder}"
                              BorderThickness="0" Margin="4">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="订单号" Width="120"
                                                DisplayMemberBinding="{Binding OrderId}"/>
                                <GridViewColumn Header="车次" Width="70"
                                                DisplayMemberBinding="{Binding TrainNo}"/>
                                <GridViewColumn Header="行程" Width="160">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="12" Foreground="#555"
                                                       VerticalAlignment="Center">
                                                <Run Text="{Binding FromStation, Mode=OneWay}"/>
                                                <Run Text=" → "/>
                                                <Run Text="{Binding ToStation, Mode=OneWay}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="日期" Width="90"
                                                DisplayMemberBinding="{Binding Date}"/>
                                <GridViewColumn Header="出发" Width="65"
                                                DisplayMemberBinding="{Binding DepartureTime}"/>
                                <GridViewColumn Header="座位" Width="65"
                                                DisplayMemberBinding="{Binding SeatType}"/>
                                <GridViewColumn Header="票价" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TotalPrice, StringFormat=¥{0:F0}}"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="#E67E22"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="状态" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="6,2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="paid">
                                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="refunded">
                                                                <Setter Property="Background" Value="#FFF3E0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="changed">
                                                                <Setter Property="Background" Value="#E3F2FD"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="unpaid">
                                                                <Setter Property="Background" Value="#FFF8E1"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" VerticalAlignment="Center"
                                                           HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="paid">
                                                                    <Setter Property="Text" Value="已支付"/>
                                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="refunded">
                                                                    <Setter Property="Text" Value="已退票"/>
                                                                    <Setter Property="Foreground" Value="#E65100"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="changed">
                                                                    <Setter Property="Text" Value="已改签"/>
                                                                    <Setter Property="Foreground" Value="#1565C0"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="unpaid">
                                                                    <Setter Property="Text" Value="待支付"/>
                                                                    <Setter Property="Foreground" Value="#F9A825"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="" Width="140">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <!-- 已支付 → 可退票 -->
                                                <Button Content="退票"
                                                        Command="{Binding DataContext.OrderList.RefundCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                        CommandParameter="{Binding}"
                                                        FontSize="12" Foreground="#D93025"
                                                        Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand" Margin="0,0,8,0">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="paid">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <!-- 已支付 → 可改签 -->
                                                <Button Content="改签"
                                                        Command="{Binding DataContext.OrderList.ChangeTicketCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                        CommandParameter="{Binding}"
                                                        FontSize="12" Foreground="#E67E22"
                                                        Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="paid">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- ==================== 后台管理页面（管理员） ==================== -->
        <Grid Grid.Row="1"
              Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=后台管理}"
              Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- 全局工具栏 -->
                <RowDefinition Height="Auto"/>   <!-- 站点管理 -->
                <RowDefinition Height="*"/>      <!-- 车次管理 -->
            </Grid.RowDefinitions>

            <!-- ===== 全局工具栏 ===== -->
            <Border Grid.Row="0" Background="White" CornerRadius="8"
                    Padding="14,10" Margin="0,0,0,8"
                    BorderBrush="#E8E8E8" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Button Content="🔄 刷新全部"
                            Click="AdminRefresh_Click"
                            FontSize="13" Foreground="#888"
                            Background="Transparent" BorderBrush="#D0D0D0"
                            BorderThickness="1" Cursor="Hand"
                            Padding="12,5" Height="30"/>
                    <TextBlock Text="{Binding AdminPanel.SuccessMessage}"
                               FontSize="12" Foreground="#2E7D32"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <TextBlock Text="{Binding AdminPanel.ErrorMessage}"
                               FontSize="12" Foreground="#D93025"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- ===== 站点管理 ===== -->
            <Border Grid.Row="1" Background="White" CornerRadius="8"
                    Padding="12,0" Margin="0,0,0,8"
                    BorderBrush="#E8E8E8" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 站点标题 + 操作 -->
                    <Grid Grid.Row="0" Margin="0,12,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="站点管理" FontSize="14" FontWeight="Bold"
                                       Foreground="#333" VerticalAlignment="Center"/>
                            <TextBlock FontSize="12" Foreground="#999"
                                       VerticalAlignment="Center" Margin="8,0,0,0">
                                <Run Text="共 "/>
                                <Run Text="{Binding AdminPanel.Stations.Count, Mode=OneWay}"/>
                                <Run Text=" 个站点"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="+ 新增站点"
                                    Click="AdminAddStation_Click"
                                    FontSize="12" Foreground="White"
                                    Background="#67C23A" BorderThickness="0"
                                    Cursor="Hand" Padding="12,4" Height="28">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="4" BorderThickness="0">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#5DAF35"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- 站点列表（紧凑行） -->
                    <Border Grid.Row="1" BorderBrush="#F0F0F0" BorderThickness="0,1,0,0">
                        <ItemsControl ItemsSource="{Binding AdminPanel.Stations}"
                                      MaxHeight="160">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,7" BorderBrush="#F5F5F5"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Background="#4A90D9" CornerRadius="4"
                                                    Width="36" Height="28" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding Code}"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13" Foreground="#333"
                                                           FontWeight="Bold"/>
                                                <TextBlock Text="{Binding City}"
                                                           FontSize="11" Foreground="#999"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button Content="编辑"
                                                        Command="{Binding DataContext.AdminPanel.EditStationCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        FontSize="11" Foreground="#4A90D9"
                                                        Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand" Margin="0,0,4,0"/>
                                                <Button Content="删除"
                                                        Command="{Binding DataContext.AdminPanel.DeleteStationCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        FontSize="11" Foreground="#D93025"
                                                        Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </Grid>
            </Border>

            <!-- ===== 车次管理 ===== -->
            <Border Grid.Row="2" Background="White" CornerRadius="8"
                    BorderBrush="#E8E8E8" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 车次标题 + 操作 -->
                    <Grid Grid.Row="0" Margin="12,12,12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="车次管理" FontSize="14" FontWeight="Bold"
                                       Foreground="#333" VerticalAlignment="Center"/>
                            <TextBlock FontSize="12" Foreground="#999"
                                       VerticalAlignment="Center" Margin="8,0,0,0">
                                <Run Text="共 "/>
                                <Run Text="{Binding AdminPanel.Trains.Count, Mode=OneWay}"/>
                                <Run Text=" 趟车次"/>
                            </TextBlock>
                        </StackPanel>
                        <Button Content="+ 新增车次"
                                Click="AdminAddTrain_Click"
                                FontSize="12" FontWeight="Bold"
                                Foreground="White" Background="#4A90D9"
                                BorderThickness="0" Cursor="Hand"
                                Padding="12,4" Height="28"
                                HorizontalAlignment="Right">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4" BorderThickness="0">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3A7BC8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <!-- 加载中 -->
                    <Border Grid.Row="1" Background="#80FFFFFF"
                            Visibility="{Binding AdminPanel.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="加载中..." FontSize="14" Foreground="#888"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 空状态 -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding AdminPanel.Trains.Count, Converter={StaticResource ZeroToVisibleConverter}}">
                        <TextBlock Text="还没有车次数据" FontSize="15" Foreground="#BBB"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="点击「新增车次」添加"
                                   FontSize="13" Foreground="#CCC"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- 车次表格 -->
                    <ListView Grid.Row="1" ItemsSource="{Binding AdminPanel.Trains}"
                              SelectedItem="{Binding AdminPanel.SelectedTrain}"
                              BorderThickness="0" Margin="4">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="车次" Width="70"
                                                DisplayMemberBinding="{Binding TrainNo}"/>
                                <GridViewColumn Header="出发站" Width="80"
                                                DisplayMemberBinding="{Binding FromStation}"/>
                                <GridViewColumn Header="到达站" Width="80"
                                                DisplayMemberBinding="{Binding ToStation}"/>
                                <GridViewColumn Header="出发" Width="70"
                                                DisplayMemberBinding="{Binding DepartureTime}"/>
                                <GridViewColumn Header="到达" Width="70"
                                                DisplayMemberBinding="{Binding ArrivalTime}"/>
                                <GridViewColumn Header="历时" Width="70"
                                                DisplayMemberBinding="{Binding Duration}"/>
                                <GridViewColumn Header="座位类型" Width="160">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <ItemsControl ItemsSource="{Binding SeatTypes}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock FontSize="11" Foreground="#555">
                                                            <Run Text="{Binding Type, Mode=OneWay}"/>
                                                            <Run Text=" ¥" Foreground="#4A90D9"/>
                                                            <Run Text="{Binding Price, StringFormat={}{0:F0}, Mode=OneWay}" Foreground="#4A90D9"/>
                                                            <Run Text="  |  "/>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="" Width="140">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="编辑"
                                                        Command="{Binding DataContext.AdminPanel.EditTrainCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                        CommandParameter="{Binding}"
                                                        FontSize="12" Foreground="#4A90D9"
                                                        Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand" Margin="0,0,8,0"/>
                                                <Button Content="删除"
                                                        Command="{Binding DataContext.AdminPanel.DeleteTrainCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                        CommandParameter="{Binding}"
                                                        FontSize="12" Foreground="#D93025"
                                                        Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- ==================== 个人中心页面 ==================== -->
        <Grid Grid.Row="1"
              Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=个人中心}"
              Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 头像卡片 -->
            <Border Grid.Row="0" Background="White" CornerRadius="8"
                    Padding="20,16" Margin="0,0,0,12"
                    BorderBrush="#E8E8E8" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Border Width="56" Height="56" CornerRadius="28"
                            Background="#4A90D9">
                        <TextBlock Text="👤" FontSize="26"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Profile.WelcomeTitle}"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="#333"/>
                        <TextBlock FontSize="12" Foreground="#999">
                            <Run Text="角色："/>
                            <Run Text="{Binding Profile.Role, Mode=OneWay}"/>
                            <Run Text="  ·  可添加最多 5 人"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 身份信息管理 -->
            <Border Grid.Row="1" Background="White" CornerRadius="8"
                    BorderBrush="#E8E8E8" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 标题栏 -->
                    <Grid Grid.Row="0" Margin="16,14,16,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="常用乘车人" FontSize="15" FontWeight="Bold"
                                       Foreground="#333" VerticalAlignment="Center"/>
                            <TextBlock FontSize="12" Foreground="#999"
                                       VerticalAlignment="Center" Margin="8,0,0,0">
                                <Run Text="{Binding Profile.Passengers.Count, Mode=OneWay}"/>
                                <Run Text=" / 5 人"/>
                            </TextBlock>
                        </StackPanel>
                        <Button Content="+ 添加"
                                Command="{Binding Profile.StartAddCommand}"
                                FontSize="13" FontWeight="Bold"
                                Foreground="White" Background="#67C23A"
                                BorderThickness="0" Cursor="Hand"
                                Padding="14,5" Height="30"
                                HorizontalAlignment="Right">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4" BorderThickness="0">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#5DAF35"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#C0E0B0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <!-- 消息 -->
                    <Border Grid.Row="1" Margin="16,0,16,8" Padding="10,8"
                            CornerRadius="6" Background="#F0FFF0"
                            BorderBrush="#C8E6C9" BorderThickness="1"
                            Visibility="{Binding Profile.SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding Profile.SuccessMessage}"
                                   FontSize="12" Foreground="#2E7D32"/>
                    </Border>
                    <Border Grid.Row="1" Margin="16,0,16,8" Padding="10,8"
                            CornerRadius="6" Background="#FFF3F3"
                            BorderBrush="#FFD4D4" BorderThickness="1"
                            Visibility="{Binding Profile.ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding Profile.ErrorMessage}"
                                   FontSize="12" Foreground="#D93025"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- 编辑表单 -->
                    <Border Grid.Row="1" Margin="40,8,40,8"
                            Padding="20,16" CornerRadius="8"
                            Background="#F8F9FB" BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            Visibility="{Binding Profile.IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock FontSize="15" FontWeight="Bold" Foreground="#333"
                                       Margin="0,0,0,14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="编辑乘车人"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Profile.IsNewPassenger}" Value="True">
                                                <Setter Property="Text" Value="新增乘车人"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- 真实姓名 -->
                            <TextBlock Text="真实姓名" FontSize="12" Foreground="#888" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Profile.EditRealName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="34" FontSize="13" Padding="8,0"
                                     VerticalContentAlignment="Center" Margin="0,0,0,12"/>

                            <!-- 身份证号 -->
                            <TextBlock Text="身份证号" FontSize="12" Foreground="#888" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Profile.EditIdCard, UpdateSourceTrigger=PropertyChanged}"
                                     Height="34" FontSize="13" Padding="8,0"
                                     MaxLength="18"
                                     VerticalContentAlignment="Center" Margin="0,0,0,12"/>

                            <!-- 手机号 -->
                            <TextBlock Text="联系手机（可选）" FontSize="12" Foreground="#888" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Profile.EditPhone, UpdateSourceTrigger=PropertyChanged}"
                                     Height="34" FontSize="13" Padding="8,0"
                                     MaxLength="11"
                                     VerticalContentAlignment="Center" Margin="0,0,0,16"/>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="保存"
                                        Command="{Binding Profile.SavePassengerCommand}"
                                        Width="80" Height="32" FontSize="13"
                                        FontWeight="Bold" Foreground="White"
                                        Cursor="Hand" Margin="0,0,10,0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#4A90D9"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="4" BorderThickness="0">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3A7BC8"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#B0C4DE"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="取消"
                                        Command="{Binding Profile.CancelEditCommand}"
                                        FontSize="13" Foreground="#888"
                                        Background="#F0F0F0" BorderThickness="0"
                                        Cursor="Hand" Width="70" Height="32">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="4" BorderThickness="0">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 已保存乘客列表 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Margin="16,0">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Profile.IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Profile.IsListEmpty}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <ItemsControl ItemsSource="{Binding Profile.Passengers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="12,10"
                                            CornerRadius="6" Background="#F8F9FB"
                                            BorderBrush="#E8E8E8" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="40" Height="40"
                                                    CornerRadius="20" Background="#E3F2FD"
                                                    Margin="0,0,12,0">
                                                <TextBlock Text="👤" FontSize="18"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding RealName}"
                                                           FontSize="14" FontWeight="Bold"
                                                           Foreground="#333"/>
                                                <TextBlock Text="{Binding IdCard}"
                                                           FontSize="12" Foreground="#999"
                                                           Margin="0,3,0,0"/>
                                                <TextBlock Text="{Binding Phone}"
                                                           FontSize="11" Foreground="#BBB"
                                                           Margin="0,1,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Content="编辑"
                                                        Command="{Binding DataContext.Profile.StartEditCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        FontSize="12" Foreground="#4A90D9"
                                                        Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand" Margin="0,0,6,0"/>
                                                <Button Content="删除"
                                                        Command="{Binding DataContext.Profile.DeletePassengerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        FontSize="12" Foreground="#D93025"
                                                        Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 空列表提示 -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Profile.IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Profile.IsListEmpty}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="👥" FontSize="40" HorizontalAlignment="Center"
                                   Opacity="0.3"/>
                        <TextBlock Text="还没有添加乘车人" FontSize="14"
                                   Foreground="#BBB" HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="点击右上角「添加」添加常用乘车人"
                                   FontSize="12" Foreground="#CCC"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</Window>
