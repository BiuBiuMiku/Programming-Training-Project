<Window x:Class="TTPFrontEnd.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:TTPFrontEnd.ViewModels"
        mc:Ignorable="d"
        Title="铁路票务系统 - 登录"
        Width="420" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Border Background="White"
            CornerRadius="12"
            BorderBrush="#E0E0E0"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0"
                              BlurRadius="30"
                              Color="#20000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 关闭按钮 -->
            <Button Grid.Row="0" Content="✕"
                    Width="36" Height="36" FontSize="14"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,8,8,0"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#999999" Cursor="Hand"
                    Click="CloseButton_Click" ToolTip="关闭"/>

            <!-- 标题区域 -->
            <StackPanel Grid.Row="1" Margin="0,20,0,10">
                <TextBlock Text="🚄" FontSize="40"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="铁路票务系统" FontSize="24"
                           FontWeight="Bold" Foreground="#333333"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="请登录您的账户" FontSize="13"
                           Foreground="#999999"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 用户名 -->
            <StackPanel Grid.Row="2" Margin="50,24,50,0">
                <TextBlock Text="用户名" FontSize="13"
                           Foreground="#555555" Margin="0,0,0,6"/>
                <Border BorderBrush="#D0D0D0" BorderThickness="1"
                        CornerRadius="4" Background="#F8F8F8">
                    <TextBox x:Name="UsernameBox"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Height="40" FontSize="14" Padding="12,0"
                             BorderThickness="0" Background="Transparent"
                             VerticalContentAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- 密码（含明文切换） -->
            <StackPanel Grid.Row="3" Margin="50,16,50,0">
                <TextBlock Text="密码" FontSize="13"
                           Foreground="#555555" Margin="0,0,0,6"/>
                <Border BorderBrush="#D0D0D0" BorderThickness="1"
                        CornerRadius="4" Background="#F8F8F8">
                    <Grid>
                        <!-- 密文框 -->
                        <PasswordBox x:Name="PasswordBox"
                                     PasswordChanged="PasswordBox_PasswordChanged"
                                     Height="40" FontSize="14" Padding="12,0"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"/>
                        <!-- 明文框（默认隐藏） -->
                        <TextBox x:Name="PasswordTextBox"
                                 Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                 Height="40" FontSize="14" Padding="12,0"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 Visibility="Collapsed"/>
                        <!-- 切换按钮 -->
                        <Button x:Name="TogglePasswordBtn"
                                Content="👁" Width="36" Height="36"
                                FontSize="14" Background="Transparent"
                                BorderThickness="0" Foreground="#999"
                                Cursor="Hand" HorizontalAlignment="Right"
                                Click="TogglePassword_Click" ToolTip="显示/隐藏密码"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- 错误提示 -->
            <Border Grid.Row="4" Margin="50,12,50,0"
                    Padding="10,8" CornerRadius="6"
                    Background="#FFF3F3" BorderBrush="#FFD4D4"
                    BorderThickness="1"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                           Foreground="#D93025" TextWrapping="Wrap"/>
            </Border>

            <!-- 登录按钮 -->
            <Button Grid.Row="5" Content="登  录"
                    Command="{Binding LoginCommand}"
                    Margin="50,24,50,0" Height="44"
                    FontSize="16" FontWeight="Bold"
                    Foreground="White" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#4A90D9"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="6" BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A7BC8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#B0C4DE"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- 底部操作栏 -->
            <StackPanel Grid.Row="6" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,16,0,30">
                <CheckBox IsChecked="{Binding RememberMe}"
                          Content="记住我" FontSize="12"
                          Foreground="#888888" VerticalAlignment="Center"/>
                <TextBlock Text="还没有账号？" FontSize="12"
                           Foreground="#999999" Margin="30,0,4,0"
                           VerticalAlignment="Center"/>
                <Button Content="立即注册"
                        Command="{Binding GoToRegisterCommand}"
                        FontSize="12" Foreground="#4A90D9"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" VerticalAlignment="Center"/>
            </StackPanel>

        </Grid>
    </Border>

</Window>
