<Window x:Class="TTPFrontEnd.Views.TrainDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="车次详情"
        Width="680" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="White"
            CornerRadius="10"
            BorderBrush="#E0E0E0"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="25" Color="#20000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- 关闭按钮 -->
                <RowDefinition Height="Auto"/>   <!-- 车次标题 -->
                <RowDefinition Height="Auto"/>   <!-- 基本信息 -->
                <RowDefinition Height="*"/>      <!-- 经停站表格 -->
                <RowDefinition Height="Auto"/>   <!-- 底部按钮 -->
            </Grid.RowDefinitions>

            <!-- 关闭按钮 -->
            <Button Grid.Row="0"
                    Content="✕"
                    Width="36" Height="36"
                    FontSize="14"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,8,8,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#999"
                    Cursor="Hand"
                    Click="CloseButton_Click"/>

            <!-- 车次标题 -->
            <StackPanel Grid.Row="1" Margin="24,8,24,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding TrainNo}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#4A90D9"/>
                    <TextBlock Text=" 次"
                               FontSize="16"
                               Foreground="#888"
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,3"/>
                </StackPanel>
                <TextBlock FontSize="13" Foreground="#999" Margin="0,4,0,0">
                    <Run Text="{Binding Date, Mode=OneWay}"/>
                    <Run Text=" · 全程 "/>
                    <Run Text="{Binding Duration, Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>

            <!-- 起终点信息卡片 -->
            <Border Grid.Row="2"
                    Margin="24,12,24,0"
                    Padding="18,14"
                    CornerRadius="8"
                    Background="#F8F9FB"
                    BorderBrush="#E8E8E8"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 出发 -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding DepartureTime}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#333"/>
                        <TextBlock Text="{Binding FromStation}"
                                   FontSize="15"
                                   Foreground="#555"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- 箭头 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                        <TextBlock Text="→" FontSize="24" Foreground="#4A90D9"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Duration}"
                                   FontSize="11" Foreground="#999"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- 到达 -->
                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding ArrivalTime}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#333"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding ToStation}"
                                   FontSize="15"
                                   Foreground="#555"
                                   Margin="0,4,0,0"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 经停站表格 -->
            <Border Grid.Row="3"
                    Margin="24,12,24,0"
                    BorderBrush="#E8E8E8"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 表头 -->
                    <Border Grid.Row="0"
                            Background="#F8F9FB"
                            BorderBrush="#E8E8E8"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="站序" FontSize="12" Foreground="#888"/>
                            <TextBlock Grid.Column="1" Text="站名" FontSize="12" Foreground="#888" Margin="8,0,0,0"/>
                            <TextBlock Grid.Column="2" Text="到达" FontSize="12" Foreground="#888"/>
                            <TextBlock Grid.Column="3" Text="出发" FontSize="12" Foreground="#888"/>
                            <TextBlock Grid.Column="4" Text="距离 (km)" FontSize="12" Foreground="#888"/>
                        </Grid>
                    </Border>

                    <!-- 加载 / 错误 -->
                    <Border Grid.Row="1"
                            Background="#80FFFFFF"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="加载中..." FontSize="13" Foreground="#888"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Grid.Row="1"
                               Text="{Binding ErrorMessage}"
                               FontSize="13"
                               Foreground="#D93025"
                               Margin="12"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <!-- 数据行 -->
                    <ListView Grid.Row="1"
                              ItemsSource="{Binding Stops}"
                              BorderThickness="0"
                              Margin="4,0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,7"
                                        BorderBrush="#F0F0F0"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Seq}"
                                                   FontSize="13" Foreground="#999"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Station}"
                                                   FontSize="14" Foreground="#333"
                                                   Margin="8,0,0,0"
                                                   FontWeight="Bold"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Arrive}"
                                                   FontSize="13" Foreground="#555"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Depart}"
                                                   FontSize="13" Foreground="#555"/>
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding DistanceKm, StringFormat={}{0} km}"
                                                   FontSize="13" Foreground="#999"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- 底部关闭按钮 -->
            <Button Grid.Row="4"
                    Content="关  闭"
                    Click="CloseButton_Click"
                    Width="100" Height="36"
                    Margin="0,14,0,18"
                    HorizontalAlignment="Center"
                    FontSize="13"
                    Foreground="#888"
                    Background="#F0F0F0"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>

</Window>
