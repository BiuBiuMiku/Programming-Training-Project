<Window x:Class="TTPFrontEnd.Views.ChangeTicketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="改签"
        Width="600" Height="500"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="White" CornerRadius="10"
            BorderBrush="#E0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="25" Color="#20000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="#F8F9FB"
                    BorderBrush="#E8E8E8" BorderThickness="0,0,0,1"
                    Padding="16,10">
                <Grid>
                    <TextBlock Text="{Binding StepTitle}" FontSize="17"
                               FontWeight="Bold" Foreground="#333"
                               VerticalAlignment="Center"/>
                    <Button Content="✕" Width="36" Height="36"
                            FontSize="14" Background="Transparent"
                            BorderThickness="0" Foreground="#999"
                            Cursor="Hand" HorizontalAlignment="Right"
                            Command="{Binding CloseCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                </Grid>
            </Border>

            <!-- 内容区 -->
            <Grid Grid.Row="1" Margin="20">

                <!-- 加载中 -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="查询可改签车次..." FontSize="14" Foreground="#888"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- 改签成功 -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding ChangeDone, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="✅" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="改签成功" FontSize="20" FontWeight="Bold"
                               Foreground="#2E7D32" HorizontalAlignment="Center"
                               Margin="0,12,0,0"/>
                    <TextBlock Text="{Binding ResultMessage}" FontSize="13"
                               Foreground="#555" HorizontalAlignment="Center"
                               Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- 失败 -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding OptionsLoaded}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="😞" FontSize="36" HorizontalAlignment="Center" Opacity="0.4"/>
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="13"
                               Foreground="#D93025" HorizontalAlignment="Center"
                               Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- 车次选择 -->
                <Grid Visibility="{Binding ChangeDone, Converter={StaticResource InvertBoolToVisibilityConverter}}">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding OptionsLoaded}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 原订单摘要 -->
                    <Border Grid.Row="0" Background="#F0F4FF" CornerRadius="6"
                            Padding="12,8" BorderBrush="#D0E0FF" BorderThickness="1"
                            Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="原车次：" FontSize="12" Foreground="#888"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding OldTrainNo}" FontSize="13"
                                       FontWeight="Bold" Foreground="#4A90D9"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock FontSize="12" Foreground="#555"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding FromStation, Mode=OneWay}"/>
                                <Run Text=" → "/>
                                <Run Text="{Binding ToStation, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 可选车次列表 -->
                    <ListView Grid.Row="1" ItemsSource="{Binding AvailableTrains}"
                              SelectedItem="{Binding SelectedTrain}"
                              BorderThickness="1" BorderBrush="#E8E8E8">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,6" BorderBrush="#F0F0F0"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding TrainNo}"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="#4A90D9" Width="60"
                                                   VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                                            <TextBlock FontSize="12" Foreground="#555">
                                                <Run Text="{Binding DepartureTime, Mode=OneWay}"/>
                                                <Run Text=" → "/>
                                                <Run Text="{Binding ArrivalTime, Mode=OneWay}"/>
                                            </TextBlock>
                                            <ItemsControl ItemsSource="{Binding SeatTypes}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock FontSize="11" Foreground="#999">
                                                            <Run Text="{Binding Type, Mode=OneWay}"/>
                                                            <Run Text=" ¥"/>
                                                            <Run Text="{Binding Price, StringFormat={}{0:F0}, Mode=OneWay}"/>
                                                            <Run Text=" 余"/>
                                                            <Run Text="{Binding Remain, Mode=OneWay}"/>
                                                            <Run Text="  |  "/>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="#E67E22"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PriceDiff}" Value="0">
                                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                                            <Setter Property="Text" Value="同价"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    <Setter Property="Text"
                                                            Value="{Binding PriceDiff, StringFormat=补 ¥{0:F0}}"/>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- 选定车次后选择座位 -->
                    <Border Grid.Row="2" Margin="0,8,0,0"
                            Visibility="{Binding SelectedTrain, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="#FFF8ED" CornerRadius="6"
                            Padding="10,8" BorderBrush="#FFE8C0" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="选择座位类型：" FontSize="12" Foreground="#888"
                                       VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding SelectedTrain.SeatTypes}"
                                      SelectedItem="{Binding SelectedSeatType}"
                                      DisplayMemberPath="Type"
                                      Width="140" Height="30" FontSize="13"
                                      HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <!-- 错误 -->
                    <Border Grid.RowSpan="3" Margin="0,8,0,0" Padding="10,8"
                            CornerRadius="6" Background="#FFF3F3"
                            BorderBrush="#FFD4D4" BorderThickness="1"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                                   Foreground="#D93025" TextWrapping="Wrap"/>
                    </Border>
                </Grid>

            </Grid>

            <!-- 底部按钮 -->
            <Border Grid.Row="2" Background="#FAFAFA"
                    BorderBrush="#E8E8E8" BorderThickness="0,1,0,0"
                    Padding="16,10">
                <StackPanel HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding ChangeDone, Converter={StaticResource InvertBoolToVisibilityConverter}}">
                        <Button Content="取消"
                                Command="{Binding CloseCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                Width="80" Height="34" FontSize="13" Foreground="#888"
                                Background="#F0F0F0" BorderThickness="0" Cursor="Hand"
                                Margin="0,0,12,0"/>
                        <Button Content="确认改签"
                                Command="{Binding ConfirmChangeCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                Width="100" Height="34" FontSize="13" FontWeight="Bold"
                                Foreground="White" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#E67E22"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4" BorderThickness="0">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D35400"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#DDBBA0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <Button Content="关闭"
                            Command="{Binding CloseCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Width="100" Height="34" FontSize="13" FontWeight="Bold"
                            Foreground="White" Background="#4A90D9"
                            BorderThickness="0" Cursor="Hand"
                            Visibility="{Binding ChangeDone, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4" BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
