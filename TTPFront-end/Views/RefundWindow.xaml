<Window x:Class="TTPFrontEnd.Views.RefundWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="退票"
        Width="480" Height="380"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="White" CornerRadius="10"
            BorderBrush="#E0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="25" Color="#20000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="#F8F9FB"
                    BorderBrush="#E8E8E8" BorderThickness="0,0,0,1"
                    Padding="16,10">
                <Grid>
                    <TextBlock Text="{Binding StepTitle}" FontSize="17"
                               FontWeight="Bold" Foreground="#333"
                               VerticalAlignment="Center"/>
                    <Button Content="✕" Width="36" Height="36"
                            FontSize="14" Background="Transparent"
                            BorderThickness="0" Foreground="#999"
                            Cursor="Hand" HorizontalAlignment="Right"
                            Command="{Binding CloseCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                </Grid>
            </Border>

            <!-- 内容区 -->
            <Grid Grid.Row="1" Margin="24">

                <!-- 加载中 -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="查询中..." FontSize="14" Foreground="#888"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- 费率已加载 + 未退票 -->
                <StackPanel VerticalAlignment="Center"
                            Visibility="{Binding FeeLoaded, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RefundDone}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- 车次摘要 -->
                    <TextBlock FontSize="15" FontWeight="Bold" Foreground="#333"
                               Margin="0,0,0,16">
                        <Run Text="{Binding TrainNo, Mode=OneWay}"/>
                        <Run Text=" 次 · 退票"/>
                    </TextBlock>

                    <!-- 费用明细 -->
                    <Border Background="#F8F9FB" CornerRadius="8"
                            Padding="16,14" BorderBrush="#E8E8E8" BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="原票价" FontSize="13" Foreground="#888"/>
                                <TextBlock HorizontalAlignment="Right" FontSize="14" FontWeight="Bold"
                                           Foreground="#333"
                                           Text="{Binding OriginalPrice, StringFormat=¥{0:F2}}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <TextBlock FontSize="13" Foreground="#888">
                                    <Run Text="手续费（"/>
                                    <Run Text="{Binding FeeRate, Mode=OneWay}"/>
                                    <Run Text="）"/>
                                </TextBlock>
                                <TextBlock HorizontalAlignment="Right" FontSize="14" FontWeight="Bold"
                                           Foreground="#D93025"
                                           Text="{Binding Fee, StringFormat=-¥{0:F2}}"/>
                            </Grid>
                            <Border BorderBrush="#E8E8E8" BorderThickness="0,1,0,0"
                                    Padding="0,8,0,0">
                                <Grid>
                                    <TextBlock Text="应退金额" FontSize="13" Foreground="#888"/>
                                    <TextBlock HorizontalAlignment="Right" FontSize="18" FontWeight="Bold"
                                               Foreground="#2E7D32"
                                               Text="{Binding RefundAmount, StringFormat=¥{0:F2}}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 费率说明 -->
                    <TextBlock Text="{Binding Reason}" FontSize="12" Foreground="#999"
                               Margin="4,8,0,0" TextWrapping="Wrap"/>

                    <!-- 错误 -->
                    <Border Margin="0,12,0,0" Padding="10,8" CornerRadius="6"
                            Background="#FFF3F3" BorderBrush="#FFD4D4" BorderThickness="1"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                                   Foreground="#D93025" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>

                <!-- 退票成功 -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding RefundDone, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="✅" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="退票成功" FontSize="20" FontWeight="Bold"
                               Foreground="#2E7D32" HorizontalAlignment="Center"
                               Margin="0,12,0,0"/>
                    <TextBlock FontSize="13" Foreground="#555"
                               HorizontalAlignment="Center" Margin="0,6,0,0">
                        <Run Text="退款金额："/>
                        <Run Text="{Binding RefundAmount, StringFormat=¥{0:F2}}"
                             Foreground="#2E7D32" FontWeight="Bold" FontSize="15"/>
                    </TextBlock>
                </StackPanel>

                <!-- 加载失败 -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FeeLoaded}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="😞" FontSize="36" HorizontalAlignment="Center"
                               Opacity="0.4"/>
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="13"
                               Foreground="#D93025" HorizontalAlignment="Center"
                               Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>

            <!-- 底部按钮 -->
            <Border Grid.Row="2" Background="#FAFAFA"
                    BorderBrush="#E8E8E8" BorderThickness="0,1,0,0"
                    Padding="16,10">
                <StackPanel HorizontalAlignment="Center">
                    <!-- 确认退票 -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding FeeLoaded, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RefundDone}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button Content="取消"
                                Command="{Binding CloseCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                Width="80" Height="34" FontSize="13" Foreground="#888"
                                Background="#F0F0F0" BorderThickness="0" Cursor="Hand"
                                Margin="0,0,12,0"/>
                        <Button Content="确认退票"
                                Command="{Binding ConfirmRefundCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                Width="100" Height="34" FontSize="13" FontWeight="Bold"
                                Foreground="White" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#D93025"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4" BorderThickness="0">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#C62828"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- 完成 -->
                    <Button Content="关闭"
                            Command="{Binding CloseCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Width="100" Height="34" FontSize="13" FontWeight="Bold"
                            Foreground="White" Background="#4A90D9"
                            BorderThickness="0" Cursor="Hand"
                            Visibility="{Binding RefundDone, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4" BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
