<Window x:Class="TTPFrontEnd.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:TTPFrontEnd.ViewModels"
        mc:Ignorable="d"
        Title="铁路票务系统 - 注册"
        Width="420" Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="White"
            CornerRadius="12"
            BorderBrush="#E0E0E0"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0"
                              BlurRadius="30"
                              Color="#20000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- 关闭按钮 -->
                <RowDefinition Height="Auto"/>   <!-- 标题 -->
                <RowDefinition Height="Auto"/>   <!-- 手机号 -->
                <RowDefinition Height="Auto"/>   <!-- 验证码 -->
                <RowDefinition Height="Auto"/>   <!-- 密码 -->
                <RowDefinition Height="Auto"/>   <!-- 确认密码 -->
                <RowDefinition Height="Auto"/>   <!-- 提示信息 -->
                <RowDefinition Height="Auto"/>   <!-- 注册按钮 -->
                <RowDefinition Height="Auto"/>   <!-- 返回登录 -->
            </Grid.RowDefinitions>

            <!-- ========== 关闭按钮 ========== -->
            <Button Grid.Row="0"
                    Content="✕"
                    Width="36" Height="36"
                    FontSize="14"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,8,8,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#999999"
                    Cursor="Hand"
                    Click="CloseButton_Click"
                    ToolTip="关闭"/>

            <!-- ========== 标题区域 ========== -->
            <StackPanel Grid.Row="1" Margin="0,16,0,4">
                <TextBlock Text="📱"
                           FontSize="36"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="注册新账户"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#333333"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
                <TextBlock Text="手机号快速注册"
                           FontSize="13"
                           Foreground="#999999"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- ========== 手机号 ========== -->
            <StackPanel Grid.Row="2" Margin="50,14,50,0">
                <TextBlock Text="手机号"
                           FontSize="13"
                           Foreground="#555555"
                           Margin="0,0,0,6"/>
                <Border BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="#F8F8F8">
                    <TextBox x:Name="PhoneBox"
                             Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                             Height="40"
                             FontSize="14"
                             Padding="12,0"
                             BorderThickness="0"
                             Background="Transparent"
                             MaxLength="11"
                             VerticalContentAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- ========== 验证码 ========== -->
            <StackPanel Grid.Row="3" Margin="50,12,50,0">
                <TextBlock Text="验证码"
                           FontSize="13"
                           Foreground="#555555"
                           Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            CornerRadius="4"
                            Background="#F8F8F8">
                        <TextBox x:Name="CodeBox"
                                 Text="{Binding VerifyCode, UpdateSourceTrigger=PropertyChanged}"
                                 Height="40"
                                 FontSize="14"
                                 Padding="12,0"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 MaxLength="6"
                                 VerticalContentAlignment="Center"/>
                    </Border>

                    <Button Grid.Column="1"
                            Content="{Binding SendCodeButtonText}"
                            Command="{Binding SendCodeCommand}"
                            Width="110"
                            Height="40"
                            Margin="10,0,0,0"
                            FontSize="12"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#4A90D9"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4"
                                                    BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3A7BC8"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#B0C4DE"/>
                                        <Setter Property="Foreground" Value="#E8E8E8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- ========== 密码 ========== -->
            <StackPanel Grid.Row="4" Margin="50,12,50,0">
                <TextBlock Text="密码"
                           FontSize="13"
                           Foreground="#555555"
                           Margin="0,0,0,6"/>
                <Border BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="#F8F8F8">
                    <PasswordBox x:Name="PwdBox"
                                 PasswordChanged="PasswordBox_PasswordChanged"
                                 Height="40"
                                 FontSize="14"
                                 Padding="12,0"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- ========== 确认密码 ========== -->
            <StackPanel Grid.Row="5" Margin="50,12,50,0">
                <TextBlock Text="确认密码"
                           FontSize="13"
                           Foreground="#555555"
                           Margin="0,0,0,6"/>
                <Border BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="#F8F8F8">
                    <PasswordBox x:Name="ConfirmPwdBox"
                                 PasswordChanged="ConfirmPasswordBox_PasswordChanged"
                                 Height="40"
                                 FontSize="14"
                                 Padding="12,0"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- ========== 错误 / 成功提示 ========== -->
            <StackPanel Grid.Row="6" Margin="50,8,50,0">
                <!-- 错误 -->
                <Border Padding="10,8"
                        CornerRadius="6"
                        Background="#FFF3F3"
                        BorderBrush="#FFD4D4"
                        BorderThickness="1"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               FontSize="12"
                               Foreground="#D93025"
                               TextWrapping="Wrap"/>
                </Border>
                <!-- 成功 -->
                <Border Padding="10,8"
                        CornerRadius="6"
                        Background="#F0FFF0"
                        BorderBrush="#C8E6C9"
                        BorderThickness="1"
                        Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding SuccessMessage}"
                               FontSize="12"
                               Foreground="#2E7D32"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>

            <!-- ========== 注册按钮 ========== -->
            <Button Grid.Row="7"
                    Content="注  册"
                    Command="{Binding RegisterCommand}"
                    Margin="50,16,50,0"
                    Height="44"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="White"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#4A90D9"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="6"
                                            BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A7BC8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#B0C4DE"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- ========== 返回登录 ========== -->
            <TextBlock Grid.Row="8"
                       HorizontalAlignment="Center"
                       Margin="0,14,0,24">
                <Hyperlink Command="{Binding GoBackCommand}"
                           Foreground="#4A90D9"
                           FontSize="12"
                           TextDecorations="None">
                    已有账号？返回登录
                </Hyperlink>
            </TextBlock>

        </Grid>
    </Border>

</Window>
