<Window x:Class="TTPFrontEnd.Views.StationEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:TTPFrontEnd.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="620" Height="580"
        MinWidth="500" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="White" CornerRadius="10"
            BorderBrush="#E0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="25" Color="#20000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- 标题栏 -->
                <RowDefinition Height="*"/>      <!-- 内容 -->
                <RowDefinition Height="Auto"/>   <!-- 按钮 -->
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="#F8F9FB"
                    BorderBrush="#E8E8E8" BorderThickness="0,0,0,1" Padding="16,10">
                <Grid>
                    <TextBlock Text="{Binding Title}" FontSize="17"
                               FontWeight="Bold" Foreground="#333"
                               VerticalAlignment="Center"/>
                    <Button Content="✕" Width="36" Height="36"
                            FontSize="14" Background="Transparent"
                            BorderThickness="0" Foreground="#999"
                            Cursor="Hand" HorizontalAlignment="Right"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- 内容 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel>

                    <!-- 基本信息 -->
                    <TextBlock Text="站点信息" FontSize="15" FontWeight="Bold"
                               Foreground="#333" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="站名" FontSize="12" Foreground="#888" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding StationName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="34" FontSize="13" Padding="8,0"
                                     VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="拼音码（电报码）" FontSize="12" Foreground="#888" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding StationCode, UpdateSourceTrigger=PropertyChanged}"
                                     Height="34" FontSize="13" Padding="8,0"
                                     CharacterCasing="Upper"
                                     MaxLength="3"
                                     VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="所在城市" FontSize="12" Foreground="#888" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding StationCity, UpdateSourceTrigger=PropertyChanged}"
                                     Height="34" FontSize="13" Padding="8,0"
                                     VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- 与已有站点的距离 -->
                    <TextBlock Text="与已有站点的距离（可选）" FontSize="15"
                               FontWeight="Bold" Foreground="#333"
                               Margin="0,24,0,0"/>
                    <TextBlock Text="填写与新站点之间的距离。留空或填 0 表示不设置边。"
                               FontSize="12" Foreground="#999" Margin="0,4,0,0"
                               TextWrapping="Wrap"/>

                    <ListView ItemsSource="{Binding Distances}"
                              BorderThickness="1" BorderBrush="#E8E8E8"
                              Margin="0,8,0,0" MaxHeight="220">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="已有站点" Width="180">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StationName}"
                                                       FontSize="13" Foreground="#333"
                                                       VerticalAlignment="Center" Margin="4,0"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="距离 (km)" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Distance, UpdateSourceTrigger=PropertyChanged}"
                                                     BorderThickness="0" FontSize="13" Padding="4,2"
                                                     VerticalContentAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="状态" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="12" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Distance}" Value="0">
                                                                <Setter Property="Text" Value="— 无连接"/>
                                                                <Setter Property="Foreground" Value="#CCC"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                        <Setter Property="Text" Value="已设置"/>
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- 空提示 -->
                    <Border Padding="12"
                            CornerRadius="6"
                            Background="#F0F4FF"
                            BorderBrush="#D0E0FF"
                            BorderThickness="1"
                            Visibility="{Binding Distances.Count, Converter={StaticResource ZeroToVisibleConverter}}"
                            Margin="0,8,0,0">
                        <TextBlock Text="没有已有站点，新站点将作为第一个站点添加。"
                                   FontSize="12" Foreground="#4A90D9"/>
                    </Border>

                    <!-- 错误提示 -->
                    <Border Margin="0,12,0,0" Padding="10,8" CornerRadius="6"
                            Background="#FFF3F3" BorderBrush="#FFD4D4" BorderThickness="1"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                                   Foreground="#D93025" TextWrapping="Wrap"/>
                    </Border>

                    <Border Height="12"/>
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <Border Grid.Row="2" Background="#FAFAFA"
                    BorderBrush="#E8E8E8" BorderThickness="0,1,0,0"
                    Padding="16,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取 消"
                            Command="{Binding CancelCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Width="80" Height="34" FontSize="13" Foreground="#888"
                            Background="#F0F0F0" BorderThickness="0"
                            Cursor="Hand" Margin="0,0,12,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4" BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="保 存"
                            Command="{Binding SaveCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Width="80" Height="34" FontSize="13" FontWeight="Bold"
                            Foreground="White" Background="#4A90D9"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4" BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3A7BC8"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#B0C4DE"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
